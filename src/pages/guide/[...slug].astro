---
import { getCollection, render } from 'astro:content';
import DocsLayout from '../../layouts/Docs.astro';
import { entryTitle } from '../../lib/docs';

export async function getStaticPaths() {
  const guide = await getCollection('guide');
  return guide.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<DocsLayout title={entryTitle(entry)} description={entry.data.description} section="guide">
  <Content />
</DocsLayout>
