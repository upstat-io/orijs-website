---
import { getCollection } from 'astro:content';
import { entryTitle, entryOrder } from '../lib/docs';

interface Props {
  section: 'guide' | 'docs';
  currentPath: string;
}

const { section, currentPath } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const guideEntries = (await getCollection('guide'))
  .sort((a, b) => entryOrder(a) - entryOrder(b));

const docsEntries = (await getCollection('docs'))
  .filter(e => !e.id.startsWith('_'))
  .sort((a, b) => entryOrder(a) - entryOrder(b));

function isActive(href: string) {
  return currentPath.replace(/\/$/, '') === href.replace(/\/$/, '');
}

