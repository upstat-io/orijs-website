---

<aside class="sidebar">
  <nav class="sidebar-nav" aria-label="Documentation navigation">
    <div class="sidebar-section">
      <h3 class="sidebar-heading">Guide</h3>
      <ul class="sidebar-list">
        {guideEntries.map(entry => {
          const href = `${base}/guide/${entry.id}`;
          const icon = guideIcons[entry.id];
          return (
            <li>
              <a href={href} class:list={['sidebar-link', { active: isActive(href) }]}>
                {icon && (
                  <svg class="sidebar-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <Fragment set:html={icon} />
                  </svg>
                )}
                {entryTitle(entry)}
              </a>
            </li>
          );
        })}
      </ul>
    </div>

    <div class="sidebar-divider">
      <span class="div-seg seg-green"></span>
      <span class="div-seg seg-brown"></span>
    </div>

    <div class="sidebar-section">
      <h3 class="sidebar-heading">API Reference</h3>
      <ul class="sidebar-list">
        {docsEntries.map(entry => {
          const href = `${base}/docs/${entry.id}`;
          const icon = docsIcons[entry.id];
          return (
            <li>
              <a href={href} class:list={['sidebar-link', { active: isActive(href) }]}>
                {icon && (
                  <svg class="sidebar-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <Fragment set:html={icon} />
                  </svg>
                )}
                {entryTitle(entry)}
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  </nav>
</aside>

<style>
  .sidebar {
    width: 260px;
    flex-shrink: 0;
    padding: 28px 16px 40px 20px;
    border-right: 1px solid var(--glass-border);
    background: rgba(13, 11, 8, 0.5);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    position: sticky;
    top: 60px;
    height: calc(100vh - 60px);
    overflow-y: auto;
  }

  .sidebar-section {
    margin-bottom: 8px;
  }

  .sidebar-heading {
    padding-left: 10px;
    margin-bottom: 8px;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
  }

  .sidebar-divider {
    display: flex;
    gap: 3px;
    height: 3px;
    margin: 16px 10px;
  }

  .div-seg {
    border-radius: var(--radius-pill);
  }

  .div-seg:first-child { flex: 2; }
  .div-seg:last-child { flex: 1; }

  .seg-green { background: var(--green-500); opacity: 0.4; }
  .seg-brown { background: var(--brown-500); opacity: 0.4; }

  .sidebar-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .sidebar-link {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.82rem;
    padding: 6px 10px;
    border-radius: var(--radius-sm);
    color: var(--text-secondary);
    transition: color 0.15s, background 0.15s;
    line-height: 1.4;
    text-decoration: none;
  }

  .sidebar-icon {
    width: 15px;
    height: 15px;
    flex-shrink: 0;
    opacity: 0.8;
    transition: opacity 0.15s;
  }

  .sidebar-link:hover {
    color: var(--text-primary);
    background: rgba(255, 255, 255, 0.04);
  }

  .sidebar-link:hover .sidebar-icon {
    opacity: 0.9;
  }

  .sidebar-link.active {
    color: var(--green-400);
    background: rgba(74, 124, 89, 0.1);
  }

  .sidebar-link.active .sidebar-icon {
    opacity: 1;
  }

  .sidebar::-webkit-scrollbar {
    width: 4px;
  }

  .sidebar::-webkit-scrollbar-track {
    background: transparent;
  }

  .sidebar::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.08);
    border-radius: 4px;
  }

  @media (max-width: 768px) {
    .sidebar {
      width: 100%;
      position: static;
      height: auto;
      border-right: none;
      border-bottom: 1px solid var(--glass-border);
      padding: 16px;
    }

    .sidebar-nav {
      display: flex;
      gap: 32px;
    }

    .sidebar-section {
      margin-bottom: 0;
    }

    .sidebar-divider {
      display: none;
    }

    .sidebar-list {
      display: flex;
      flex-wrap: wrap;
      gap: 4px;
    }

    .sidebar-icon {
      display: none;
    }
  }
</style>
